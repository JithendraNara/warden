  {
    "id": "agentic-review-startup-fix",
    "workflow": "agentic_review",
    "inputs": {
      "repo": "example/demo",
      "pr": 7,
      "pr_title": "Fix startup crash",
      "pr_body": "Adds a guard for missing config.",
      "diff": "--- a/src/main.py\n+++ b/src/main.py\n@@ -1,2 +1,3 @@\n+# guard missing config\n def main():\n     print('hello')\n"
